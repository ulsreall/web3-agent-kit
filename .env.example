# Web3 Agent Kit — Environment Configuration
# Copy this file to .env and fill in your values

# Wallet private key (required for transactions)
PRIVATE_KEY=

# RPC URLs (optional — defaults to public RPCs)
ETH_RPC_URL=https://eth.llamarpc.com
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
POLYGON_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
BERA_RPC_URL=https://rpc.berachain.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# AI Provider (optional — for LLM-powered agent)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
KIMI_API_KEY=

# Transaction Simulator (optional — for Tenderly mode)
TENDERLY_API_KEY=
TENDERLY_USER=
TENDERLY_PROJECT=

# Account Abstraction (optional — for ERC-4337)
PIMLICO_API_KEY=
AA_BUNDLER_URL=
AA_PAYMASTER_URL=

# Cross-chain Messaging (optional)
LAYERZERO_API_KEY=
WORMHOLE_RPC=

# Governance (optional — for Tally API)
TALLY_API_KEY=

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASS=
ALERT_EMAIL_TO=

# Airdrop Automation (optional)
GALXE_AUTH_TOKEN=
ZEALY_API_KEY=
